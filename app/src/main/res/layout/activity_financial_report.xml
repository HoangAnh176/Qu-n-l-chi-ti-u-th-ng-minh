<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">
    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="0dp"/>
        <RadioGroup
            android:id="@+id/rg_report_type"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="#E0E0E0">
            <RadioButton
                android:id="@+id/rb_monthly"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:text="Hàng tháng"
                android:textColor="#FFF"
                android:button="@null"
                android:gravity="center"
                android:background="#FF9800"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rb_yearly"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:text="Hàng năm"
                android:button="@null"
                android:textColor="#FF9800"
                android:gravity="center"
                android:background="#F5F5F5"/>
        </RadioGroup>
        <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="0dp"/>
    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"
        android:layout_below="@id/top_bar">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Date Selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="#FDF1E6"
                android:padding="12dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/btn_prev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_back"
                    app:tint="#666" />
                <TextView
                    android:id="@+id/tv_date_range"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="04/2026 (01/04 - 30/04)"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textColor="#333"
                    android:textStyle="bold"/>
                <ImageView
                    android:id="@+id/btn_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_next"
                    app:tint="#666" />
            </LinearLayout>
            <!-- Summary Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_margin="16dp"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Expense -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chi tiêu" android:textColor="#666"/>
                        <TextView android:id="@+id/tv_total_expense" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-190,000Ä‘" android:textColor="#F44336" android:gravity="end" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEE" android:layout_marginHorizontal="12dp"/>
                    <!-- Income -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu nhập" android:textColor="#666"/>
                        <TextView android:id="@+id/tv_total_income" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="+50,000Ä‘" android:textColor="#2196F3" android:gravity="end" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" android:layout_marginVertical="12dp"/>
                <!-- Balance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu chi" android:textColor="#666"/>
                    <TextView android:id="@+id/tv_balance" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-140,000Ä‘" android:textColor="#333" android:gravity="end" android:textStyle="bold" android:textSize="20sp"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Tabs -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tabIndicatorColor="#FF9800"
                app:tabSelectedTextColor="#FF9800"
                app:tabTextColor="#999">
                <com.google.android.material.tabs.TabItem android:text="Chi tiêu" />
                <com.google.android.material.tabs.TabItem android:text="Thu nhập" />
            </com.google.android.material.tabs.TabLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD"/>
            <!-- Chart -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:layout_marginVertical="16dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD"/>
            <!-- RecyclerView list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_report_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:menu="@menu/bottom_nav_menu" />
</RelativeLayout>
