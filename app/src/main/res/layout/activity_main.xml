<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">
    <!-- Top Toolbar Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <RadioGroup
            android:id="@+id/rg_type"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_rg_type"
            android:padding="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <RadioButton
                android:id="@+id/rb_expense"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_tab_selector"
                android:textColor="@color/text_tab_selector"
                android:textStyle="bold"
                android:text="Tiền chi"
                android:gravity="center"
                android:button="@null"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rb_income"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_tab_selector"
                android:textColor="@color/text_tab_selector"
                android:textStyle="bold"
                android:text="Tiền thu"
                android:gravity="center"
                android:button="@null"/>
        </RadioGroup>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@+id/div1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/ll_top_bar"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/div1"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Ngay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Ngày"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:textSize="18sp"/>
                <ImageView
                    android:id="@+id/tv_prev_date"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_back"
                    app:tint="#555555"
                    android:gravity="center"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_btn_date"/>
                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="12/04/2026 (CN)"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <ImageView
                    android:id="@+id/tv_next_date"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_next"
                    app:tint="#555555"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_btn_date"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />
            <!-- Ghi chúu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Ghi chú"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Chưa nhập vào"
                    android:textColorHint="#BBBBBB"
                    android:textSize="18sp"
                    android:textColor="#333333"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />
            <!-- Ti?n -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_amount_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Tiền chi"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:textSize="18sp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <EditText
                        android:id="@+id/et_amount"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:background="@null"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:textColor="#333333"
                        android:textSize="24sp" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="đ"
                    android:layout_marginStart="12dp"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />
            <!-- Danh mục -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Danh mục"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="18sp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="16dp" />
            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_margin="24dp"
                android:backgroundTint="#FF8C00"
                android:text="Nhập khoản chi"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"/>
        </LinearLayout>
    </ScrollView>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"/>
    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>

